    p.add_argument("--direction", default="", help="Direction ID (inherits from hypothesis if omitted)")
    p.add_argument("--backend", default="local", help="Compute backend")
    p.add_argument("--id", default="", help="Custom ID (auto-generated if omitted)")
    p.set_defaults(func=cmd_experiment)

    # result
    p = sub.add_parser("result", help="Log what happened")
    p.add_argument("experiment", help="Experiment ID")
    p.add_argument("--verdict", "-v", required=True, choices=["keep", "discard", "crash", "inconclusive"])
    p.add_argument("--metrics", default="{}", help="JSON metrics")
    p.add_argument("--interpretation", "-i", default="", help="What happened")
    p.add_argument("--insight", default="", help="What you learned")
    p.add_argument("--mechanism-confirmed", action="store_true", help="The hypothesized mechanism was correct")
    p.add_argument("--mechanism-refuted", action="store_true", help="The hypothesized mechanism was wrong")
    p.add_argument("--theory-revision", default="", help="How your understanding changed")
    p.add_argument("--wall-time", type=float, default=0.0, help="Wall time in seconds")
    p.set_defaults(func=cmd_result)

    # insight
    p = sub.add_parser("insight", help="Log a learning")
    p.add_argument("content", help="What you learned")
    p.add_argument("--type", default="observation",
                   choices=["observation", "literature", "synthesis", "theory_update", "novel_approach"])
    p.add_argument("--tags", default="", help="Comma-separated tags")
    p.add_argument("--confidence", type=float, default=0.5)
    p.set_defaults(func=cmd_insight)

    # direction
    p = sub.add_parser("direction", help="Register a research thread")
    p.add_argument("title", help="Direction name")
    p.add_argument("--theory", "-t", default="", help="Why this direction should work")
    p.add_argument("--parent", default="", help="Parent direction (if pivoting)")
    p.add_argument("--id", default="", help="Custom ID (derived from title if omitted)")
    p.set_defaults(func=cmd_direction)

    # synthesize
    p = sub.add_parser("synthesize", help="Reflect across experiments")
    p.add_argument("content", help="Your synthesis")
    p.add_argument("--experiments", default="", help="Comma-separated experiment IDs covered")
    p.add_argument("--decision", default="continue",
                   choices=["continue", "pivot", "branch", "novel_approach", "success", "failure"])
    p.add_argument("--theory-before", default="", help="Mental model before synthesis")
    p.add_argument("--theory-after", default="", help="Mental model after synthesis")
    p.add_argument("--direction", default="", help="Direction ID")
    p.set_defaults(func=cmd_synthesize)

    # validate
    p = sub.add_parser("validate", help="Pre-run readiness check")
    p.add_argument("hypothesis", help="Hypothesis ID")
    p.add_argument("--cost", type=float, default=0.0, help="Estimated cost in USD")
    p.set_defaults(func=cmd_validate)

    # context
    p = sub.add_parser("context", help="Full research history")
    p.set_defaults(func=cmd_context)

    # status
    p = sub.add_parser("status", help="Campaign health check")
    p.set_defaults(func=cmd_status)

    # best
    p = sub.add_parser("best", help="Best result so far")
    p.set_defaults(func=cmd_best)

    # failures
    p = sub.add_parser("failures", help="Failed approaches")
    p.set_defaults(func=cmd_failures)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
