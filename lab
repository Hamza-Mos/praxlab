#!/usr/bin/env python3
"""lab — structured experiment tracking for autonomous research.

5 commands. One SQLite database. No dependencies beyond stdlib.

Usage (from any leaf directory):
    ../lab hypothesis "increase LR to 0.04" -m "higher LR = faster convergence in early training"
    ../lab experiment h1
    ../lab result e1 -v keep --metrics '{"val_bpb": 0.993}'
    ../lab context          # full research state (for session start)
    ../lab failures         # what didn't work (don't repeat these)
"""

import argparse
import json
import sqlite3
import subprocess
from datetime import datetime, timezone
from pathlib import Path

# ── Paths ──

def _main_repo_root():
    """Find the main repo root via git, so DB is shared across worktrees."""
    try:
        common = subprocess.check_output(
            ["git", "rev-parse", "--git-common-dir"],
            cwd=Path(__file__).resolve().parent,
            stderr=subprocess.DEVNULL,
        ).decode().strip()
        # --git-common-dir returns the .git dir (or main repo's .git for worktrees)
        return Path(common).resolve().parent
    except (subprocess.CalledProcessError, FileNotFoundError):
        return Path(__file__).resolve().parent

HARNESS_DIR = _main_repo_root()
DB_PATH = HARNESS_DIR / "data" / "experiments.db"

SCHEMA = """
CREATE TABLE IF NOT EXISTS hypotheses (
    id TEXT PRIMARY KEY,
    title TEXT NOT NULL,
    mechanism TEXT NOT NULL,
    status TEXT DEFAULT 'proposed',
    created_at TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS experiments (
    id TEXT PRIMARY KEY,
    hypothesis_id TEXT REFERENCES hypotheses(id),
    task_id TEXT NOT NULL,
    status TEXT DEFAULT 'running',
    created_at TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS results (
    experiment_id TEXT PRIMARY KEY REFERENCES experiments(id),
    metrics_json TEXT DEFAULT '{}',
    mechanism_confirmed INTEGER,
    theory_revision TEXT,
    verdict TEXT NOT NULL,
    created_at TEXT NOT NULL
);
"""


# ── Helpers ──

def _now():
    return datetime.now(timezone.utc).isoformat()


def _task_id():
    """Derive task_id from CWD path relative to harness root."""
    cwd = Path.cwd().resolve()
    try:
        rel = cwd.relative_to(HARNESS_DIR)
        return str(rel).replace("/", "-").replace("\\", "-")
    except ValueError:
        return cwd.name


def _get_db():
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    db = sqlite3.connect(str(DB_PATH))
    db.row_factory = sqlite3.Row
    db.execute("PRAGMA journal_mode = WAL")
    db.execute("PRAGMA busy_timeout = 5000")
    db.execute("PRAGMA foreign_keys = ON")
    db.executescript(SCHEMA)
    return db


def _next_id(db, table, prefix):
    row = db.execute(f"SELECT MAX(CAST(SUBSTR(id, 2) AS INTEGER)) as max_n FROM {table}").fetchone()
    return f"{prefix}{(row['max_n'] or 0) + 1}"


# ── Commands ──

def cmd_hypothesis(args):
    """Register what you're testing and WHY."""
    db = _get_db()
    db.execute("BEGIN IMMEDIATE")
    hid = _next_id(db, "hypotheses", "h")
    db.execute(
        "INSERT INTO hypotheses (id, title, mechanism, status, created_at) VALUES (?,?,?,?,?)",
        (hid, args.title, args.mechanism, "proposed", _now()),
    )
    db.commit()
    db.close()
    print(hid)


def cmd_experiment(args):
    """Log an experiment before running it."""
    db = _get_db()
    db.execute("BEGIN IMMEDIATE")
    task_id = _task_id()
    eid = _next_id(db, "experiments", "e")
    db.execute(
        "INSERT INTO experiments (id, hypothesis_id, task_id, status, created_at) VALUES (?,?,?,?,?)",
        (eid, args.hypothesis, task_id, "running", _now()),
    )
    db.execute("UPDATE hypotheses SET status = 'testing' WHERE id = ? AND status = 'proposed'", (args.hypothesis,))
    db.commit()
    db.close()
    print(eid)


def cmd_result(args):
    """Log what happened after running."""
    db = _get_db()
    db.execute("BEGIN IMMEDIATE")
    metrics = json.loads(args.metrics) if args.metrics else {}

    mech_val = None
    if args.mechanism_confirmed:
        mech_val = 1
    elif args.mechanism_refuted:
        mech_val = 0

    db.execute(
        """INSERT INTO results (experiment_id, metrics_json, mechanism_confirmed,
           theory_revision, verdict, created_at) VALUES (?,?,?,?,?,?)
           ON CONFLICT(experiment_id) DO UPDATE SET
             metrics_json=excluded.metrics_json, mechanism_confirmed=excluded.mechanism_confirmed,
             theory_revision=excluded.theory_revision, verdict=excluded.verdict""",
        (args.experiment, json.dumps(metrics), mech_val,
         args.theory_revision or None, args.verdict, _now()),
    )
    db.execute("UPDATE experiments SET status = ? WHERE id = ?", (args.verdict, args.experiment))

    # Update hypothesis status (only promote: proposed → testing → confirmed; never demote)
    row = db.execute("SELECT hypothesis_id FROM experiments WHERE id = ?", (args.experiment,)).fetchone()
    if row:
        current = db.execute("SELECT status FROM hypotheses WHERE id = ?", (row["hypothesis_id"],)).fetchone()
        if current and current["status"] != "confirmed":
            new_status = "confirmed" if args.verdict == "keep" else "tested"
            db.execute("UPDATE hypotheses SET status = ? WHERE id = ?", (new_status, row["hypothesis_id"]))

    db.commit()
    db.close()
    print(args.verdict)


def cmd_context(_args):
    """Dump full research state for session reconstruction."""
    db = _get_db()
    task_id = _task_id()

    # Recent experiments
    recent = db.execute(
        """SELECT e.id, h.title, h.mechanism, r.verdict, r.metrics_json,
                  r.mechanism_confirmed, r.theory_revision
           FROM experiments e
           JOIN hypotheses h ON e.hypothesis_id = h.id
           LEFT JOIN results r ON e.id = r.experiment_id
           WHERE e.task_id = ? ORDER BY e.created_at DESC LIMIT 20""",
        (task_id,),
    ).fetchall()

    count = db.execute("SELECT COUNT(*) as cnt FROM experiments WHERE task_id = ?", (task_id,)).fetchone()["cnt"]
    db.close()

    print(f"## Research Context: {task_id}")
    print(f"Experiments: {count}")

    if recent:
        print(f"\n### History")
        for r in reversed(list(recent)):
            mech = ""
            if r["mechanism_confirmed"] is not None:
                mech = " | mechanism: " + ("confirmed" if r["mechanism_confirmed"] else "refuted")
            rev = f" | revision: {r['theory_revision']}" if r["theory_revision"] else ""
            print(f"  {r['title']}: {r['verdict'] or 'running'} | {r['metrics_json'] or '{}'}{mech}{rev}")
    else:
        print("\nNo experiments yet.")


def cmd_failures(_args):
    """List failed approaches so you don't repeat them."""
    task_id = _task_id()
    db = _get_db()
    rows = db.execute(
        """SELECT h.title, h.mechanism, r.theory_revision FROM experiments e
           JOIN hypotheses h ON e.hypothesis_id = h.id
           JOIN results r ON e.id = r.experiment_id
           WHERE e.task_id = ? AND r.verdict IN ('discard', 'crash')
           ORDER BY e.created_at DESC""",
        (task_id,),
    ).fetchall()
    db.close()

    if not rows:
        print("No failures yet.")
    else:
        for r in rows:
            rev = f" -> {r['theory_revision']}" if r["theory_revision"] else ""
            print(f"- {r['title']}: {r['mechanism']}{rev}")


# ── CLI ──

def main():
    parser = argparse.ArgumentParser(prog="lab", description="Structured experiment tracking")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("hypothesis", help="Register what you're testing and WHY")
    p.add_argument("title", help="What you're testing")
    p.add_argument("--mechanism", "-m", required=True, help="WHY this should work")
    p.set_defaults(func=cmd_hypothesis)

    p = sub.add_parser("experiment", help="Log before running")
    p.add_argument("hypothesis", help="Hypothesis ID (e.g. h1)")
    p.set_defaults(func=cmd_experiment)

    p = sub.add_parser("result", help="Log after running")
    p.add_argument("experiment", help="Experiment ID (e.g. e1)")
    p.add_argument("--verdict", "-v", required=True, choices=["keep", "discard", "crash"])
    p.add_argument("--metrics", default="{}", help="JSON metrics")
    p.add_argument("--mechanism-confirmed", action="store_true")
    p.add_argument("--mechanism-refuted", action="store_true")
    p.add_argument("--theory-revision", default="", help="How your understanding changed")
    p.set_defaults(func=cmd_result)

    p = sub.add_parser("context", help="Full research state")
    p.set_defaults(func=cmd_context)

    p = sub.add_parser("failures", help="Failed approaches")
    p.set_defaults(func=cmd_failures)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
